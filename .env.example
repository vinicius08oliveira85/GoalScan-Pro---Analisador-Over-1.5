# Configuração da API do Gemini
# Obtenha sua chave em: https://aistudio.google.com/
GEMINI_API_KEY=sua_chave_aqui

# Chave fallback do Gemini (opcional)
GEMINI_API_KEY_FALLBACK=sua_chave_fallback_aqui

# --- Supabase (projeto GoalScan) ---
# Dashboard: https://supabase.com/dashboard/project/abjzfxucwcvumkuqapkr
# Settings > API: copie "Project URL" e a chave anon "public" (nunca commite o .env)
VITE_SUPABASE_URL=https://abjzfxucwcvumkuqapkr.supabase.co
VITE_SUPABASE_ANON_KEY=cole_aqui_a_chave_anon_public

# Vite expõe apenas variáveis com prefixo VITE_ (já usado em lib/supabase.ts)
